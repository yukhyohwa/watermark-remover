# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# C extensions
*.so

# Environments
.env
.venv
env/
venv/
ENV/
env.bak/
venv.bak/

# IDE / Editor
.vscode/
.idea/
*.swp
*.swo

# Project specific ignores
# Ignore all images so we don't accidentally commit sensitive screenshots with watermarks
*.jpg
*.jpeg
*.png
*.bmp
*.tiff
*.webp

# Except test assets if you eventually make a test folder
!tests/assets/*.jpg

# Ignore generated output directories
input/
output/
